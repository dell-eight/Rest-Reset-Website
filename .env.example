# Public analytics IDs.
# Leave blank locally if you do not have real IDs yet. The app safely no-ops without them.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Optional canonical site URL used by metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Public checkout URLs.
# Leave blank until Shopify/payment-provider links exist; blank values use the on-page checkout placeholder.
NEXT_PUBLIC_SLEEP_RESET_KIT_CHECKOUT_URL=
NEXT_PUBLIC_WEIGHTED_EYE_MASK_CHECKOUT_URL=
NEXT_PUBLIC_COOLING_PILLOWCASE_CHECKOUT_URL=
NEXT_PUBLIC_BLUE_LIGHT_GLASSES_CHECKOUT_URL=
NEXT_PUBLIC_WHITE_NOISE_MACHINE_CHECKOUT_URL=
NEXT_PUBLIC_SLEEP_JOURNAL_CHECKOUT_URL=
